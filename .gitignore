# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# babadoc local storage (user-uploaded images)
/uploads/
/public/uploads/

# prisma sqlite
prisma/dev.db
prisma/dev.db-journal

# local utility scripts (may contain credentials)
scripts/

# local investigation files, notebooks, and data dumps
*.py
*.txt
*.log
*.mmd
*.csv

# corporate seed files (only seed.ts is safe for repo)
prisma/seed-*.ts
prisma/extract_*.py
prisma/delete-edge.ts
prisma/check_questions.ts
prisma/query.ts
prisma/reset-*.ts
prisma/*.json
prisma/*.py

# local JSON data dumps (may contain corporate data)
docs_ai_*.json
*_lineage_*.json
*_payload.json

# notebook exports
notebook_*.py

# build error logs
build_error_*.txt
output.log
*_resultado*.txt
